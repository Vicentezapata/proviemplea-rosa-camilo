# Puerto del servidor (Render lo asigna automáticamente via PORT)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here_use_a_long_random_string
JWT_EXPIRES_IN=8h

# Base de datos para desarrollo local
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=proviemplea_api_grupal
DB_USER=root
DB_PASS=

# Base de datos para producción (Clever Cloud / Railway / etc.)
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@host:port/database
